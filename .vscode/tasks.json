{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "go",
      "args": ["test", "./..."],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Kanban Backend",
      "type": "shell",
      "command": "go",
      "args": ["run", ".", "serve"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Kanban Frontend",
      "type": "shell",
      "command": "npm install && npm run dev -- --host 0.0.0.0",
      "options": {
        "cwd": "${workspaceFolder}/web"
      }
    }
  ]
}
